# Core
NODE_ENV=production
DB_PATH=openlib.db
DATA_DIR=data
SCREENSHOT_DIR=data/cache/screenshots
LOG_DIR=logs

# GitHub REST API
# Unauthenticated mode works, but a fine-grained token with public repo read access is strongly recommended.
GITHUB_TOKEN=
GITHUB_USER_AGENT=openlib-crawler
GITHUB_PER_PAGE=30
GITHUB_MAX_PAGES_PER_QUERY=3
MIN_STARS=100
INACTIVE_DAYS=365
TARGET_APPS_PER_RUN=50
CRAWLER_CONCURRENCY=2
MIN_QUALITY_SCORE=70

# Comma-separated or newline-separated query list.
GITHUB_SEARCH_QUERIES=topic:opensource stars:>200 archived:false fork:false,topic:desktop-app stars:>200 archived:false fork:false,topic:linux-app stars:>100 archived:false fork:false,topic:electron stars:>500 archived:false fork:false,topic:self-hosted stars:>500 archived:false fork:false

# Screenshot cache
SCREENSHOTS_ENABLED=true
SCREENSHOT_CONCURRENCY=2
MAX_SCREENSHOTS_PER_APP=6
SCREENSHOT_MIN_WIDTH=240
SCREENSHOT_MIN_HEIGHT=160
SCREENSHOT_WEBP_QUALITY=78

# Local AI only: Ollama must be installed and running.
AI_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=tinyllama
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_CTX=1024
OLLAMA_NUM_PREDICT=180
AI_CONCURRENCY=1
AI_MAX_INPUT_CHARS=1200

# OpenLib API sync
OPENLIB_API_URL=https://openlib.example.com/api
OPENLIB_API_KEY=
SYNC_BATCH_SIZE=25
SYNC_CONCURRENCY=1

# Local moderation backend
MODERATION_HOST=127.0.0.1
MODERATION_PORT=3020
MODERATION_API_KEY=change-me
